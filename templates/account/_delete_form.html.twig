<form method="post"
      action="{{ path('app_account_delete', {'id': account.id}) }}"
      onsubmit="return confirm('Are you sure you want to delete this item?');"
      style="max-width: 18px; display: inline-flex;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ account.id) }}">
    <button class="btn btn-link"><i class="bi bi-trash"></i></button>
</form>
