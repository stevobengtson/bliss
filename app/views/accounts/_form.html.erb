<% form_for [@budget, account] do |form| %>
    <% if account.errors.any? %>
        <div style="color: red"><%= pluralize(account.errors.count, "error") %> prohibited this account from being saved:</h2>
            <ul>
<% account.errors.each do |error| %>
<%= error.full_message %></li>
                <% end %>
            </ul>
