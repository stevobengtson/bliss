<nav aria-label="Page navigation example" {{ attributes }}>
    <ul class="pagination">
        {% for page in this.pages %}
        <li class="page-item{{ page.active ? ' active' : '' }}{{ page.disabled ? ' disabled' : '' }}">
            <a class="page-link" href="{{ page.link }}">{{ page.display }}</a>
        </li>
        {% endfor %}
    </ul>
</nav>
