<%= render partial: "components/navbar", locals: { title: "Budgets", new_item: new_budget_path, new_item_title: "New Budget" } %>

<div class="mt-3">
  <div class="row row-cols-1 row-cols-md-3 rows-cols-lg-5 g-4">
    <% @budgets.each do |budget| %>
    <div class="col">
      <div class="card text-center h-100">
        <div class="card-header">
          <%= budget.name %>
        </div>
        <div class="card-body d-flex p-2 bd-highlight justify-content-center">
          <%= link_to "Load", budget, class: "btn btn-outline-primary m-4" %>
          <%= link_to "Edit", edit_budget_path(budget), class: "btn btn-outline-secondary m-4" %>
          <%= button_to "Delete", budget, method: :delete, class: "btn btn-outline-danger m-4" %>
        </div>
        <div class="card-footer">
          <small class="text-body-secondary">Last updated: <%= time_ago_in_words(budget.updated_at) %></small>
        </div>
      </div>
    </div>
    <% end %>
  </div>
</div>
