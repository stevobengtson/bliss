{% extends 'main_base.html.twig' %}

{% block title %}{{ account.nickName }}{% endblock %}

{% block content %}
    <h1>{{ account.nickName }}! ✅</h1>
    <table class="table table-dark table-sm">
    <thead>
    <tr>
        <th>Date</th>
        <th>Category</th>
        <th>Credit</th>
        <th>Debit</th>
        <th>Balance</th>
    </tr>
    </thead>
    <tbody>
    {% for transaction in account.transactions %}
    <tr>
        <td>{{ transaction.enteredDate }}</td>
        <td>Unknown</td>
        <td>{{ transaction.credit }}</td>
        <td>{{ transaction.debit }}</td>
        <td>--</td>
    </tr>
    {% endfor %}
    </tbody>
    </table>
{% endblock %}
