{% extends 'base.html.twig' %}

{% block title %}Edit Account{% endblock %}

{% block body %}
    {% embed 'components/_card.html.twig' %}
        {% block header_left %}
            {{ include('components/_back_to_list.html.twig', { 'back_path': 'app_account_index'}) }}
        {% endblock %}

        {% block header_center %}
            <h3 class="text-center font-weight-light my-4">Edit {{ account.nickName }}</h3>
        {% endblock %}

        {% block card_body %}
            {{ include('account/_form.html.twig', {'button_label': 'Update'}) }}
        {% endblock %}
    {% endembed %}
{% endblock %}
